# ---------------------------------------------------------------
# Application
# ---------------------------------------------------------------
NODE_ENV=development
PORT=3000
API_PREFIX=/api/v1

# ---------------------------------------------------------------
# Logging
# ---------------------------------------------------------------
# One of: error | warn | info | http | debug
LOG_LEVEL=debug
LOG_DIR=src/logs

# ---------------------------------------------------------------
# MongoDB
# ---------------------------------------------------------------
MONGO_URI=mongodb://localhost:27017/media_pipeline
MONGO_DB_NAME=media_pipeline

# ---------------------------------------------------------------
# Redis (used by BullMQ)
# ---------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ---------------------------------------------------------------
# BullMQ
# ---------------------------------------------------------------
IMAGE_QUEUE_NAME=image-processing
WORKER_CONCURRENCY=4
JOB_ATTEMPTS=3
JOB_BACKOFF_MS=5000
# Run the BullMQ worker inside the API process. Convenient for local dev;
# set to false in production and run `npm run worker` as its own service.
START_WORKER_IN_API=true

# ---------------------------------------------------------------
# Uploads
# ---------------------------------------------------------------
UPLOAD_DIR=src/uploads
# Max upload size in bytes (default 10MB)
MAX_UPLOAD_BYTES=10485760
# Comma-separated list of accepted mime types
ALLOWED_MIME_TYPES=image/jpeg,image/png,image/webp

# ---------------------------------------------------------------
# CORS
# ---------------------------------------------------------------
CORS_ORIGIN=*
