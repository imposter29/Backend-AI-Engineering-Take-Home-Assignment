{
  "name": "intelligent-media-processing-pipeline",
  "version": "1.0.0",
  "description": "Production-grade backend pipeline for asynchronous image upload, analysis (blur/brightness/duplicates/OCR/number-plate validation) and structured result delivery.",
  "type": "module",
  "main": "src/server.js",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "worker": "node src/workers/index.js",
    "worker:dev": "nodemon src/workers/index.js",
    "lint": "eslint \"src/**/*.js\"",
    "format": "prettier --write \"src/**/*.js\"",
    "test": "echo \"TODO: add tests\" && exit 0"
  },
  "keywords": [
    "image-processing",
    "ocr",
    "bullmq",
    "express",
    "mongodb",
    "redis",
    "tesseract",
    "sharp"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "bullmq": "^5.12.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "helmet": "^7.1.0",
    "ioredis": "^5.4.1",
    "joi": "^17.13.3",
    "mongoose": "^8.5.1",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "sharp": "^0.33.4",
    "tesseract.js": "^5.1.0",
    "uuid": "^10.0.0",
    "winston": "^3.13.1",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "eslint": "^9.7.0",
    "nodemon": "^3.1.4",
    "prettier": "^3.3.3"
  }
}
